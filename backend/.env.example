# Novel Builder 后端环境变量配置示例
# 复制此文件为 .env 并填写实际值

# =============================================================================
# 必需配置 (生产环境必须设置)
# =============================================================================

# API访问令牌 - 生产环境必须设置强密码
NOVEL_API_TOKEN=your-secure-api-token-here

# JWT密钥 - 用于签名和验证JWT令牌
SECRET_KEY=your-super-secret-jwt-key-here-32-chars

# 数据库连接 - PostgreSQL生产数据库
DATABASE_URL=postgresql://novel_user:novel_pass@postgres:5432/novel_db

# =============================================================================
# 可选配置
# =============================================================================

# 启用的小说站点 (用逗号分隔)
# 活跃站点: alice_sw, ddxsmf, shukuge, wdscw, wodeshucheng, wfxs, biquge543
# 禁用站点: xspsw (HTTP 520), smxku (403 反爬)
NOVEL_ENABLED_SITES=alice_sw,ddxsmf,shukuge,wdscw,wodeshucheng,wfxs,biquge543

# 调试模式 (生产环境设为 false)
DEBUG=false

# CORS允许的源 (用逗号分隔，生产环境设置具体域名)
CORS_ORIGINS=http://localhost:3154,https://yourdomain.com

# 视频生成超时时间 (秒)
VIDEO_GENERATION_TIMEOUT=600

# =============================================================================
# 开发环境示例配置
# =============================================================================

# 开发环境配置示例
# NOVEL_API_TOKEN=dev-token-123
# DEBUG=true
# DATABASE_URL=sqlite:///./novel_cache.db
# CORS_ORIGINS=http://localhost:3154

# =============================================================================
# 生产环境示例配置
# =============================================================================

# 生产环境配置示例
# NOVEL_API_TOKEN=Prod-Token-Abc123!@#StrongPassword
# DEBUG=false
# DATABASE_URL=postgresql://novel_user:secure_password@db.example.com:5432/novel_prod
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# AI 功能配置
# =============================================================================

# ComfyUI 服务 - AI 图片/视频生成
COMFYUI_API_URL=http://host.docker.internal:8188

# =============================================================================
# API 兼容性配置（保留以兼容旧配置）
# =============================================================================

# API Configuration (legacy, kept for compatibility)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO
