# 快速测试用 Dockerfile - 跳过浏览器安装
FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 配置阿里云镜像
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources && \
    sed -i 's/security.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources

# 只安装 Scrapling 运行时依赖（不安装 Playwright 浏览器）
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    libcurl4 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 配置 PyPI 镜像
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/

# 复制依赖文件
COPY pyproject.toml ./

# 只安装 Scrapling 核心依赖（不安装 Playwright）
RUN pip install --no-cache-dir "scrapling[fetchers]>=0.4.0" && \
    pip install --no-cache-dir "scrapling[core]>=0.4.0" && \
    pip install --no-cache-dir -e . 2>&1 | tail -20

# 复制应用代码
COPY ./app ./app
COPY ./alembic.ini ./
COPY ./alembic ./alembic

# 验证安装
RUN python -c "from scrapling import Fetcher; print('Scrapling Fetcher 安装成功')"

EXPOSE 8000

# 启动命令（不启动服务器，只验证）
CMD ["python", "-c", "from scrapling import Fetcher; print('Scrapling 测试通过')"]
